# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=troque_por_uma_string_aleatoria_longa_e_segura
JWT_EXPIRES_IN=30d

# ── SQL Server (autenticação SQL — usuário + senha) ───────────────────────────
DB_SERVER=localhost
DB_PORT=1433
DB_DATABASE=cedro
DB_USER=sa
DB_PASSWORD=sua_senha_aqui

# ── SQL Server (autenticação Windows — deixe DB_USER e DB_PASSWORD em branco) ─
# DB_TRUSTED_CONNECTION=true
